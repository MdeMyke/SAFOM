generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int        @id @default(autoincrement())
  cedula           String     @unique
  nombre           String
  correo           String     @unique
  password         String
  telefono         String?
  lastLoginAt      DateTime?  @map("last_login_at")
  passwordChangeAt DateTime?  @map("password_change_at")
  createdBy        Int?       @map("created_by")
  updatedBy        Int?       @map("updated_by")
  deletedBy        Int?       @map("deleted_by")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  deletedAt        DateTime?  @map("deleted_at")
  roles            UserRole[]
  sessions         Session[]

  // Relaciones inversas (requeridas por Prisma)
  ticketsCreados    Ticket[]           @relation("TicketUsuario")
  comentarios       Comentario[]       @relation("ComentarioUsuario")
  historialCreado   HistorialTicket[]  @relation("HistorialCreador")
  asignacionesA     TicketAsignacion[] @relation("AsignacionUsuario")
  asignacionesPor   TicketAsignacion[] @relation("AsignacionPor")
  ticketsArchivados Ticket[]           @relation("TicketArchivadoPor")

  conversacionesChatActual             Conversacion[]             @relation("ConversacionUsuarioActual")
  asignacionesConversacionUsuario      AsignacionConversacion[]   @relation("AsignacionConversacionUsuario")
  asignacionesConversacionAsignadoPor  AsignacionConversacion[]   @relation("AsignacionConversacionAsignadoPor")
  asignacionesConversacionDesasignado  AsignacionConversacion[]   @relation("AsignacionConversacionDesasignadoPor")
  eventosChat                          EventoChat[]               @relation("EventoChatUsuario")
}

model Session {
  id           Int      @id @default(autoincrement())
  userId       Int?     @map("user_id")
  refreshToken String   @map("refresh_token") @db.Text
  ipAddress    String?  @map("ip_address") @db.VarChar(50)
  userAgent    String?  @map("user_agent") @db.Text
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("sessions")
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          Int              @id @default(autoincrement())
  action      String
  resource    String
  description String?
  roles       RolePermission[]

  @@unique([action, resource])
  @@map("Permisos")
}

model UserRole {
  id         Int      @id @default(autoincrement())
  userId     Int
  roleId     Int
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int
  permissionId Int
  assignedAt   DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("RolePermisos")
}

// =========================
// CATALOGOS
// =========================

model Categoria {
  id          Int     @id @default(autoincrement())
  nombre      String
  descripcion String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy Int?      @map("created_by")
  updatedBy Int?      @map("updated_by")
  deletedBy Int?      @map("deleted_by")

  subcategorias Subcategoria[]
  tickets       Ticket[]       @relation("TicketCategoria")

  @@map("categorias")
}

model Subcategoria {
  id          Int     @id @default(autoincrement())
  categoriaId Int     @map("categoria_id")
  nombre      String
  descripcion String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy Int?      @map("created_by")
  updatedBy Int?      @map("updated_by")
  deletedBy Int?      @map("deleted_by")

  categoria Categoria @relation(fields: [categoriaId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  tickets   Ticket[]  @relation("TicketSubcategoria")

  @@map("subcategorias")
}

model Prioridad {
  id     Int    @id @default(autoincrement())
  nombre String
  nivel  Int

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy Int?      @map("created_by")
  updatedBy Int?      @map("updated_by")
  deletedBy Int?      @map("deleted_by")

  tickets Ticket[]

  @@map("prioridades")
}

model Estado {
  id     Int    @id @default(autoincrement())
  nombre String
  // Catalogo esperado:
  // 1. abierto
  // 2. asignado
  // 3. en_progreso
  // 4. pendiente_aprobacion
  // 5. resuelto
  // 6. cerrado

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy Int?      @map("created_by")
  updatedBy Int?      @map("updated_by")
  deletedBy Int?      @map("deleted_by")

  tickets Ticket[]

  @@map("estados")
}

// =========================
// TICKETS
// =========================

model Ticket {
  id          Int     @id @default(autoincrement())
  codigo      String  @unique
  titulo      String
  descripcion String? @db.Text

  solicitanteUserId Int @map("solicitante_user_id")
  categoriaId       Int @map("categoria_id")
  subcategoriaId    Int @map("subcategoria_id")
  prioridadId       Int @map("prioridad_id")
  estadoId          Int @map("estado_id")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  archivadoAt DateTime? @map("archivado_at")
  archivadoBy Int?      @map("archivado_by")
  deletedAt   DateTime? @map("deleted_at")
  createdBy   Int?      @map("created_by")
  updatedBy   Int?      @map("updated_by")
  deletedBy   Int?      @map("deleted_by")

  user         User         @relation("TicketUsuario", fields: [solicitanteUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  archivadoPor User?        @relation("TicketArchivadoPor", fields: [archivadoBy], references: [id], onDelete: SetNull, onUpdate: Cascade)
  categoria    Categoria    @relation("TicketCategoria", fields: [categoriaId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  subcategoria Subcategoria @relation("TicketSubcategoria", fields: [subcategoriaId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  prioridad    Prioridad    @relation(fields: [prioridadId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  estado       Estado       @relation(fields: [estadoId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  comentarios  Comentario[]
  historial    HistorialTicket[]
  asignaciones TicketAsignacion[]

  @@map("tickets")
}

// =========================
// COMENTARIOS
// =========================

model Comentario {
  id         Int     @id @default(autoincrement())
  ticketId   Int     @map("ticket_id")
  userId     Int     @map("user_id")
  comentario String? @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy Int?      @map("created_by")
  updatedBy Int?      @map("updated_by")
  deletedBy Int?      @map("deleted_by")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user   User   @relation("ComentarioUsuario", fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("comentarios_tickets")
}

// =========================
// HISTORIAL
// =========================

model HistorialTicket {
  id            Int     @id @default(autoincrement())
  ticketId      Int     @map("ticket_id")
  accion        String
  descripcion   String? @db.Text
  valorAnterior Json?   @map("valor_anterior") @db.Json
  valorNuevo    Json?   @map("valor_nuevo") @db.Json

  createdBy Int @map("created_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  updatedBy Int?      @map("updated_by")
  deletedBy Int?      @map("deleted_by")

  ticket  Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  creador User   @relation("HistorialCreador", fields: [createdBy], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("historial_tickets")
}

// =========================
// ASIGNACIONES
// =========================

model TicketAsignacion {
  id          Int      @id @default(autoincrement())
  ticketId    Int      @map("ticket_id")
  userId      Int      @map("user_id")
  asignadoPor Int      @map("asignado_por")
  esActual    Boolean  @map("es_actual")
  asignadoEn  DateTime @map("asignado_en")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user   User   @relation("AsignacionUsuario", fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  por    User   @relation("AsignacionPor", fields: [asignadoPor], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("ticket_asignaciones")
}

// =========================
// CHATBOT / WHATSAPP
// =========================

model Conversacion {
  id              Int       @id @default(autoincrement())
  waId            String    @unique @map("wa_id")
  nombre          String?
  estado          String    @default("abierto")
  estadoFlujo     String?   @map("estado_flujo")
  telefono        String?
  cedula          String?
  currentUserId   Int?      @map("current_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  currentUser User? @relation("ConversacionUsuarioActual", fields: [currentUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  mensajes                Mensaje[]
  asignaciones            AsignacionConversacion[]
  eventos                 EventoChat[]
  historialEstadosConversacion HistorialEstadoConversacion[]

  @@index([waId])
  @@map("conversaciones")
}

model Mensaje {
  id              Int      @id @default(autoincrement())
  conversacionId  Int      @map("conversacion_id")
  idExterno       String   @unique @map("id_externo")
  enviadoPorMi    Boolean  @map("enviado_por_mi") @db.TinyInt
  tipo            String
  contenido       String?  @db.Text
  meta            Json?    @db.Json
  createdAt       DateTime @default(now()) @map("created_at")

  conversacion Conversacion @relation(fields: [conversacionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  adjuntos     Adjunto[]

  @@index([conversacionId])
  @@index([createdAt])
  @@map("mensajes")
}

model Adjunto {
  id         Int      @id @default(autoincrement())
  mensajeId  Int      @map("mensaje_id")
  urlArchivo String   @map("url_archivo")
  tipo       String
  tamano     Int?
  createdAt  DateTime @default(now()) @map("created_at")

  mensaje Mensaje @relation(fields: [mensajeId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([mensajeId])
  @@map("adjuntos")
}

model Flujo {
  id        Int      @id @default(autoincrement())
  nombre    String
  createdAt DateTime @default(now()) @map("created_at")

  estados EstadoFlujo[]
  reglas  ReglaFlujo[]

  @@map("flujos")
}

model EstadoFlujo {
  id           Int      @id @default(autoincrement())
  flujoId      Int      @map("flujo_id")
  nombreEstado String   @map("nombre_estado")
  createdAt    DateTime @default(now()) @map("created_at")

  flujo Flujo @relation(fields: [flujoId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  reglasComoActual    ReglaFlujo[] @relation("ReglaEstadoActual")
  reglasComoSiguiente ReglaFlujo[] @relation("ReglaSiguienteEstado")

  @@index([flujoId])
  @@map("estados_flujo")
}

model ReglaFlujo {
  id                Int      @id @default(autoincrement())
  flujoId           Int      @map("flujo_id")
  estadoActualId    Int      @map("estado_actual_id")
  tipoDisparador    String   @map("tipo_disparador")
  valorDisparador   String?  @map("valor_disparador")
  textoRespuesta    String   @map("texto_respuesta") @db.Text
  siguienteEstadoId Int      @map("siguiente_estado_id")
  createdAt         DateTime @default(now()) @map("created_at")

  flujo           Flujo       @relation(fields: [flujoId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  estadoActual    EstadoFlujo @relation("ReglaEstadoActual", fields: [estadoActualId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  siguienteEstado EstadoFlujo @relation("ReglaSiguienteEstado", fields: [siguienteEstadoId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([flujoId, estadoActualId, tipoDisparador, valorDisparador])
  @@index([flujoId, estadoActualId])
  @@map("reglas_flujo")
}

model AsignacionConversacion {
  id             Int       @id @default(autoincrement())
  conversacionId Int       @map("conversacion_id")
  userId         Int       @map("user_id")
  assignedAt     DateTime  @default(now()) @map("assigned_at")
  assignedBy     Int?      @map("assigned_by")
  unassignedAt   DateTime? @map("unassigned_at")
  unassignedBy   Int?      @map("unassigned_by")
  isActive       Boolean   @default(true) @map("is_active") @db.TinyInt

  conversacion Conversacion @relation(fields: [conversacionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user         User         @relation("AsignacionConversacionUsuario", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  asignadoPor  User?        @relation("AsignacionConversacionAsignadoPor", fields: [assignedBy], references: [id], onDelete: SetNull, onUpdate: Cascade)
  desasignadoPor User?      @relation("AsignacionConversacionDesasignadoPor", fields: [unassignedBy], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([conversacionId])
  @@index([userId])
  @@map("asignaciones_conversacion")
}

model EventoChat {
  id             Int      @id @default(autoincrement())
  tipoEvento     String   @map("tipo_evento")
  userId         Int?     @map("user_id")
  conversacionId Int?     @map("conversacion_id")
  createdAt      DateTime @default(now()) @map("created_at")

  user         User?         @relation("EventoChatUsuario", fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  conversacion Conversacion? @relation(fields: [conversacionId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([conversacionId])
  @@index([userId])
  @@index([createdAt])
  @@map("eventos")
}

model HistorialEstadoConversacion {
  id                       Int      @id @default(autoincrement())
  conversacionId           Int      @map("conversacion_id")
  estadoAnterior           String   @map("estado_anterior")
  estadoNuevo              String   @map("estado_nuevo")
  idMensajeDisparador      String   @map("id_mensaje_disparador")
  createdAt                DateTime @default(now()) @map("created_at")

  conversacion Conversacion @relation(fields: [conversacionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([conversacionId])
  @@index([createdAt])
  @@map("historial_estados_conversacion")
}
